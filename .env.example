# NEXUS Agentic OS — Non-secret configuration
# Copy to .env and fill in values. NO API KEYS HERE — use vault for secrets.

# Home Assistant
HASS_HOST=http://192.168.1.x:8123

# UniFi
UNIFI_HOST=https://192.168.1.1
UNIFI_USERNAME=admin

# Unraid (host only, key goes in vault)
UNRAD_HOST=192.168.1.x

# Obsidian REST plugin
OBSIDIAN_HOST=http://localhost:27123

# Channels DVR
CHANNELS_HOST=http://192.168.1.x:8089

# AdGuard Home
ADGUARD_HOST=http://192.168.1.x:3000
ADGUARD_USER=admin

# Hermes Bridge
HERMES_HOST=http://192.168.1.x:9000

# GitHub
GITHUB_USERNAME=yourusername

# Briefing schedule (24h format, local timezone)
BRIEFING_TIME=07:00
BRIEFING_TIMEZONE=America/Detroit

# Voice
MEMO_WATCH_FOLDER=./watched_memos
WHISPER_API=false
WHISPER_MODEL=base

# Weather location (lat/lon)
WEATHER_LAT=42.33
WEATHER_LON=-83.04

# Ports
NEXUS_PORT=3000
BACKEND_PORT=8000

# Misc
PR_STALE_HOURS=48
DEBUG=false

# Frontend — override API/WS target for LAN access from tablets/phones
# VITE_API_BASE=http://192.168.1.x:8000
# VITE_WS_BASE=ws://192.168.1.x:8000
